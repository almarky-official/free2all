# Public site URL used for canonical tags, sitemap, and metadata.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional Google Search Console verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional hidden network fallback for blocked sites.
# Example: http://username:password@proxy-host:proxy-port
FREE2ALL_MEDIA_PROXY_URL=

# blocked-only = use fallback only when the first request is blocked
# always = always start downloads through the fallback route
# disabled = never use the fallback route
FREE2ALL_MEDIA_PROXY_MODE=blocked-only

# Optional browser-cookie fallback for login-protected sources.
# Supported example values: chrome, edge
FREE2ALL_COOKIES_FROM_BROWSER=
